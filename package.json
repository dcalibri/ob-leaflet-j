{
  "name": "obsidian-plugin-leaflet-j2",
  "version": "1.0.0",
  "description": "Leaflet map transformer for Quartz v5",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": "./dist/index.js"
  },
  "quartz": {
    "name": "obsidian-plugin-leaflet-j2",
    "description": "Interactive Leaflet maps from codeblocks",
    "author": "dcalibri",
    "authorUrl": "https://github.com/dcalibri",
    "pluginType": "transformer"
  },
  "scripts": {
    "build": "tsc && tsup src/index.ts --format esm --dts",
    "dev": "tsc --watch"
  },
  "dependencies": {
    "@quartz-community/types": "latest",
    "unist-util-visit": "^4.1.2"
  },
  "devDependencies": {
    "typescript": "^5.0.0",
    "tsup": "^7.0.0"
  }
}